# MongoDB (loaded only in server.ts)
#
# If mongodb+srv fails with querySrv ECONNREFUSED (common on some Windows DNS), either:
# - leave defaults (server uses public DNS 8.8.8.8 / 1.1.1.1 for SRV), or
# - set MONGODB_DIRECT_URI to Atlas "standard connection string" (mongodb://… :27017,…).
# MONGODB_DIRECT_URI=
#
# MONGODB_USE_PUBLIC_DNS=false
#
# Option A — full SRV URI (URL-encode password if it contains @ : / ? # [ ])
# MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/
#
# Option B — password in MONGODB_PASSWORD (see server resolveMongoUri)
# MONGODB_URI=mongodb+srv://USER:@CLUSTER.mongodb.net/
# MONGODB_PASSWORD=your_atlas_db_password
#
# Option C — parts only (leave MONGODB_URI empty)
# MONGODB_USER=myuser
# MONGODB_PASSWORD=mypass
# MONGODB_CLUSTER=cluster0.xxxxx.mongodb.net
#
MONGODB_URI=
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_CLUSTER=
DB_NAME=healthbuddy

# HTTP port (default 3000). Change if you see EADDRINUSE.
# PORT=3001

# JWT Secret for Authentication
JWT_SECRET="5960400662bad5bb528fee1739663b2b58ef6283456038add4d8e337c4bcbf31"

# Google OAuth — Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Paste your Web client ID and secret here. Restart the dev server after changing.
#
# redirect_uri_mismatch fix: In Google Cloud Console → your OAuth client → Authorized redirect URIs,
# add EVERY URL your app might use — host and port must match what you type in the browser:
#   http://localhost:3000/api/auth/google/callback
#   http://127.0.0.1:3000/api/auth/google/callback
# (localhost and 127.0.0.1 are different to Google. No trailing slash. Use http for local dev.)
# If you set GOOGLE_OAUTH_REDIRECT_URI below, use that exact string in the Console too.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: override callback URL (must match Console exactly). If unset, dev uses canonical localhost (see below).
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
#
# Dev default: redirect is always http://localhost:PORT/api/auth/google/callback so Google Console only needs ONE URI
# even if you open the site as http://127.0.0.1:PORT. After login, use http://localhost:PORT in the browser.
# Set to false to send redirect_uri based on the Host header (then add both localhost and 127.0.0.1 in Console).
# GOOGLE_REDIRECT_USE_LOCALHOST=false
#
# Behind nginx/HTTPS reverse proxy: TRUST_PROXY=true (so redirect uses correct https + host)
# TRUST_PROXY=false
# Optional: where to send the browser after login (defaults to request URL). Set in production.
# APP_ORIGIN=http://localhost:3000

# Groq API Key
GROQ_API_KEY=""

# Gemini API Key (used for uploaded medical images/files via Gemini 2.5 Flash)
GEMINI_API_KEY=""

# Tavily API Key
TAVILY_API_KEY=""

# Stripe Configuration
STRIPE_SECRET_KEY=""
VITE_STRIPE_PUBLISHABLE_KEY=""